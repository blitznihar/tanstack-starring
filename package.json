{
  "name": "comet-academy",
  "version": "0.1.0",
  "private": true,
  "productName": "Comet Academy",
  "type": "module",
  "description": "Comet — multi-program practice platform (Grade 3 STAAR + extensible programs)",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "start": "bun scripts/serve-dist.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "demo": "bun run scripts/demo.ts",
    "build-content": "bun run scripts/build-grade3-math.ts && bun run scripts/build-grade3-rla.ts",
    "seed": "bun run scripts/seed.ts",
    "import-bundle": "bun run scripts/import-bundle.ts",
    "create-user": "bun run scripts/create-user.ts",
    "export-profile": "bun run scripts/export-profile.ts",
    "import-profile": "bun run scripts/import-profile.ts",
    "send-test-notifications": "bun run scripts/send-test-notifications.ts",
    "validate:grade3:student": "bun run scripts/grade3-staar/run-student-e2e-validation.ts",
    "validate:grade3:45day": "bun run scripts/grade3-staar/run-45-day-validation.ts",
    "validate:grade3:reports-ui": "bun run scripts/grade3-staar/check-ui-reports.ts",
    "cleanup:grade3:student": "bun run scripts/grade3-staar/cleanup-validation-student.ts",
    "desktop": "bun scripts/desktop.mjs",
    "desktop:dev": "bun scripts/desktop.mjs --dev",
    "desktop:prod": "bun scripts/desktop.mjs --prod"
  },
  "overrides": {
    "vite": "7.3.5"
  },
  "build": {
    "appId": "academy.comet.desktop",
    "productName": "Comet Academy",
    "mac": {
      "icon": "electron/assets/comet-academy-icon.icns"
    },
    "win": {
      "icon": "electron/assets/comet-academy-icon.ico"
    },
    "linux": {
      "icon": "electron/assets/comet-academy-icon.png"
    }
  },
  "dependencies": {
    "@tanstack/react-query": "^5.62.0",
    "@tanstack/react-router": "^1.95.0",
    "@tanstack/react-start": "^1.95.0",
    "@vercel/analytics": "^2.0.1",
    "argon2": "^0.41.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "mongodb": "^6.12.0",
    "newrelic": "^14.1.0",
    "nodemailer": "^9.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "stripe": "^17.5.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/newrelic": "^9.14.8",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.19.0",
    "@typescript-eslint/parser": "^8.19.0",
    "@vitejs/plugin-react": "^5",
    "@vitest/coverage-v8": "3.2.6",
    "electron": "^42.4.1",
    "eslint": "^9.17.0",
    "nitro": "^3.0.260610-beta",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vite": "^7",
    "vitest": "^3"
  }
}
