{
  "name": "comet",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Comet — multi-program practice platform (Grade 3 STAAR + extensible programs)",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "start": "node .output/server/index.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "demo": "bun run scripts/demo.ts",
    "build-content": "bun run scripts/build-grade3-math.ts && bun run scripts/build-grade3-rla.ts",
    "seed": "bun run scripts/seed.ts",
    "import-bundle": "bun run scripts/import-bundle.ts",
    "create-user": "bun run scripts/create-user.ts",
    "export-profile": "bun run scripts/export-profile.ts",
    "import-profile": "bun run scripts/import-profile.ts",
    "desktop": "electron electron/main.cjs"
  },
  "overrides": {
    "vite": "7.3.5"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.62.0",
    "@tanstack/react-router": "^1.95.0",
    "@tanstack/react-start": "^1.95.0",
    "argon2": "^0.41.1",
    "mongodb": "^6.12.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "stripe": "^17.5.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.19.0",
    "@typescript-eslint/parser": "^8.19.0",
    "@vitejs/plugin-react": "^5",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vite": "^7",
    "vitest": "^3"
  }
}
